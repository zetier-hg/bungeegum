apply plugin: 'com.android.application'

dependencies {
    implementation fileTree(dir: 'libs', include: '*.jar')
}
android {
    namespace 'com.zetier.bungeegum'
    compileSdkVersion 24

    defaultConfig {
        minSdkVersion 24
        targetSdkVersion 24
        ndk {
            abiFilters "armeabi-v7a", "arm64-v8a"
        }
    }

}
